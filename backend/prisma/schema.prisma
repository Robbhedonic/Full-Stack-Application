generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER_PET
  OWNER_PLANT
  OWNER_MIXED
  CAREGIVER
  ADMIN
}

model User {
  id                    String         @id @default(cuid())
  email                 String         @unique
  passwordHash          String
  name                  String
  role                  UserRole
  profileMode           String?
  ownerPetType          String?
  ownerPlantType        String?
  ownerMealsPerDay      Int?
  ownerWateringSchedule String?
  ownerWateringAmount   String?
  ownerCareNotes        String?
  createdAt             DateTime       @default(now())
  sitterProfile         SitterProfile?
  bookings              Booking[]      @relation("OwnerBookings")
  sessions              Session[]
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model SitterProfile {
  id           String    @id @default(cuid())
  userId       String?   @unique
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  name         String
  type         String
  petTypes     String?
  availability String?
  rating       Float
  pricePerHour Int
  description  String
  location     String
  bookings     Booking[]
}

model Booking {
  id               String        @id @default(cuid())
  sitterId         String
  sitter           SitterProfile @relation(fields: [sitterId], references: [id])
  ownerId          String?
  owner            User?         @relation("OwnerBookings", fields: [ownerId], references: [id], onDelete: SetNull)
  ownerName        String
  serviceType      String
  petType          String?
  plantType        String?
  mealsPerDay      Int?
  wateringSchedule String?
  wateringAmount   String?
  careNotes        String?
  startDate        DateTime
  durationHours    Int
  status           String        @default("pending")
  createdAt        DateTime      @default(now())
}
